require_relative "tokenizer"

# A tiny decoder-only Transformer language model in pure Ruby.
#
#     token ids ─▶ embed ─▶ [Block]×N ─▶ RMSNorm ─▶ LM head ─▶ logits
#
# Each Block is "pre-norm" (LLaMA / GPT-NeoX style):
#
#     x ─▶ RMSNorm ─▶ multi-head self-attention ─▶ + ─▶ x'
#                                                  │
#                                                  └─ residual ─┐
#     x' ─▶ RMSNorm ─▶ FFN (Linear → ReLU → Linear) ─▶ + ─▶ x''
#                                                       │
#                                                       └─ residual
#
# Loss is cross-entropy on next-token prediction. The combined softmax+CE
# gradient is the clean  dL/dlogits = softmax(logits) − one_hot(target),
# so we never compute softmax separately during backward.
#
# Training uses mini-batch SGD with explicit gradient accumulation:
# zero an accumulator, add each example's gradients, divide by batch size,
# apply once. Averaging the *gradients* (not the raw errors) is what makes
# this equivalent to one step on the mean loss.
#
# Inference uses a KV cache so that generating token N+1 only does the work
# for that one new token, instead of re-running the whole context.
#
# Style notes:
#   • Pure Ruby, stdlib-free for the math (avoiding Matrix's row-vector quirks).
#   • Targets a Spinel-compilable subset: no Marshal, no instance_variable_set,
#     no metaprogramming.

# ------------------------------------------------------------------
#   Tiny matrix helper. Matrices are arrays of arrays of floats.
#   Indexing is [row][col]; "m × n" means m rows, n columns.
# ------------------------------------------------------------------
module Mat
  module_function

  # (m × n) · (n × p) → (m × p)
  def matmul(a, b)
    rows  = a.length
    inner = a[0].length
    cols  = b[0].length
    out   = Array.new(rows) { Array.new(cols, 0.0) }
    rows.times do |i|
      ai = a[i]
      inner.times do |k|
        aik = ai[k]
        next if aik == 0.0
        bk = b[k]
        cols.times { |j| out[i][j] += aik * bk[j] }
      end
    end
    out
  end

  def transpose(a)
    Array.new(a[0].length) { |j| Array.new(a.length) { |i| a[i][j] } }
  end

  def add(a, b)
    a.each_with_index.map { |row, i| row.each_with_index.map { |v, j| v + b[i][j] } }
  end

  def add!(a, b)
    a.each_with_index { |row, i| row.length.times { |j| row[j] += b[i][j] } }
    a
  end

  def scale!(a, s)
    a.each { |row| row.length.times { |j| row[j] *= s } }
    a
  end

  def zeros(rows, cols)
    Array.new(rows) { Array.new(cols, 0.0) }
  end

  def random(rows, cols, scale: 0.1)
    Array.new(rows) { Array.new(cols) { (rand * 2 - 1) * scale } }
  end

  # Row-wise softmax with the standard "subtract max" trick for stability.
  def softmax_rows(a)
    a.map do |row|
      mx  = row.max
      exp = row.map { |v| Math.exp(v - mx) }
      sum = exp.sum
      exp.map { |e| e / sum }
    end
  end

  # Concatenate matrices side-by-side: [T,a] + [T,b] → [T, a+b]
  def hstack(matrices)
    return matrices.first if matrices.length == 1
    matrices.first.each_with_index.map do |_, i|
      matrices.flat_map { |m| m[i] }
    end
  end

  # Inverse of hstack: split a [T, n*chunk] matrix into n matrices of [T, chunk].
  def hsplit(m, n_chunks)
    chunk = m[0].length / n_chunks
    Array.new(n_chunks) do |c|
      Array.new(m.length) { |i| m[i][c * chunk, chunk] }
    end
  end
end

class TransformerLM
  attr_reader :vocabulary, :word_to_index

  def initialize(vocab_size:, d_model:, d_ff:, n_heads:, context_length:, n_layers:,
                 vocabulary: nil, word_to_index: nil)
    raise "d_model (#{d_model}) must divide by n_heads (#{n_heads})" unless (d_model % n_heads).zero?

    @vocab_size     = vocab_size
    @d_model        = d_model
    @d_ff           = d_ff
    @n_heads        = n_heads
    @d_head         = d_model / n_heads
    @context_length = context_length
    @n_layers       = n_layers
    @vocabulary     = vocabulary
    @word_to_index  = word_to_index

    s = 1.0 / Math.sqrt(d_model)   # small init keeps activations from saturating

    @token_embed = Mat.random(vocab_size, d_model, scale: s)
    @pos_embed   = Mat.random(context_length, d_model, scale: s)

    @blocks = Array.new(n_layers) do
      {
        norm1_gamma: Array.new(d_model, 1.0),
        # One per head; the standard "fused" version stores these as a single
        # [d_model, d_model] matrix and slices columns. Per-head is more
        # explicit at the cost of one extra `each` loop.
        w_q:   Array.new(n_heads) { Mat.random(d_model, @d_head, scale: s) },
        w_k:   Array.new(n_heads) { Mat.random(d_model, @d_head, scale: s) },
        w_v:   Array.new(n_heads) { Mat.random(d_model, @d_head, scale: s) },
        w_o:   Mat.random(d_model, d_model, scale: s),
        norm2_gamma: Array.new(d_model, 1.0),
        w_ff1: Mat.random(d_model, d_ff,    scale: s),
        w_ff2: Mat.random(d_ff,    d_model, scale: s),
      }
    end

    @norm_final_gamma = Array.new(d_model, 1.0)
    @lm_head          = Mat.random(d_model, vocab_size, scale: s)

    init_adam_state
  end

  # Adam keeps a running estimate of the gradient's mean (m) and squared mean
  # (v) per parameter, then steps in the direction of m / sqrt(v). It adapts
  # the effective learning rate per coordinate, which is why it converges
  # so much faster than plain SGD on transformer-shaped losses.
  def init_adam_state
    @m_state = zero_gradients   # first moments  (same shape as grads)
    @v_state = zero_gradients   # second moments
    @adam_t  = 0
  end

  def self.create_from_data(data, d_model:, d_ff:, n_heads:, context_length:, n_layers:)
    words         = data.flat_map { |line| Tokenizer.tokenize_french(line) }.uniq
    word_to_index = words.each_with_index.to_h
    nn = new(vocab_size: words.size, d_model: d_model, d_ff: d_ff, n_heads: n_heads,
             context_length: context_length, n_layers: n_layers,
             vocabulary: words, word_to_index: word_to_index)
    sequences = data.map { |line| nn.text_to_token_ids(line) }.reject { |s| s.size < 2 }
    [nn, sequences]
  end

  def text_to_token_ids(text)
    Tokenizer.tokenize_french(text).map { |w| @word_to_index[w] }.compact
  end

  # =====================================================================
  #  FORWARD — full sequence, with backward-pass caching.
  # =====================================================================

  def forward(token_ids)
    raise "context overflow" if token_ids.size > @context_length

    @cache = { token_ids: token_ids, blocks: [] }

    x = embed(token_ids, start_pos: 0)
    @cache[:x_embed] = x

    @blocks.each_with_index do |block, i|
      x_in = i.zero? ? @cache[:x_embed] : @cache[:blocks][i - 1][:x_out]
      x, layer_cache = transformer_block(x_in, block)
      @cache[:blocks] << layer_cache
    end

    x_normed, rms_final = rms_norm(x, @norm_final_gamma)
    @cache[:x_block_out] = x
    @cache[:x_final]     = x_normed
    @cache[:rms_final]   = rms_final

    logits = Mat.matmul(x_normed, @lm_head)
    @cache[:logits] = logits
    logits
  end

  # x[i] = token_embed[token_ids[i]] + pos_embed[start_pos + i]
  def embed(token_ids, start_pos: 0)
    Array.new(token_ids.size) do |i|
      tok = @token_embed[token_ids[i]]
      pos = @pos_embed[start_pos + i]
      Array.new(@d_model) { |j| tok[j] + pos[j] }
    end
  end

  def transformer_block(x, block)
    cache = {}

    h, rms1 = rms_norm(x, block[:norm1_gamma])
    attn_proj, attn_cache = self_attention(h, block)
    x_attn  = Mat.add(x, attn_proj)
    cache.merge!(rms1: rms1, h_norm1: h, attn_cache: attn_cache, x_attn: x_attn)

    h2, rms2 = rms_norm(x_attn, block[:norm2_gamma])
    ff_out, ff_cache = feed_forward(h2, block)
    x_out = Mat.add(x_attn, ff_out)
    cache.merge!(rms2: rms2, h_norm2: h2, ff_cache: ff_cache, x_out: x_out)

    [x_out, cache]
  end

  # RMSNorm: y_j = gamma_j * x_j / sqrt(mean(x²) + eps),  per row.
  def rms_norm(x, gamma, eps: 1e-5)
    d   = gamma.length
    rms = x.map { |row| Math.sqrt(row.sum { |v| v * v } / d + eps) }
    y   = x.each_with_index.map do |row, i|
      r = rms[i]
      row.each_with_index.map { |v, j| v * gamma[j] / r }
    end
    [y, rms]
  end

  # Multi-head self-attention with causal masking.
  #
  # For each head h:
  #     q_h = h · W_q[h]   (T × d_head)
  #     k_h = h · W_k[h]
  #     v_h = h · W_v[h]
  #     scores = q_h · k_hᵀ / sqrt(d_head)        (T × T, mask above diagonal)
  #     out_h  = softmax(scores) · v_h            (T × d_head)
  #
  # Concatenate {out_h} → (T × d_model), then project: out · W_o.
  def self_attention(h_in, block)
    inv_sqrt = 1.0 / Math.sqrt(@d_head)

    per_head = Array.new(@n_heads) do |head_idx|
      q = Mat.matmul(h_in, block[:w_q][head_idx])
      k = Mat.matmul(h_in, block[:w_k][head_idx])
      v = Mat.matmul(h_in, block[:w_v][head_idx])

      scores = Mat.matmul(q, Mat.transpose(k))
      Mat.scale!(scores, inv_sqrt)
      apply_causal_mask!(scores, query_offset: 0)

      attn = Mat.softmax_rows(scores)
      out  = Mat.matmul(attn, v)

      { q: q, k: k, v: v, attn: attn, out: out }
    end

    concat = Mat.hstack(per_head.map { |head| head[:out] })
    proj   = Mat.matmul(concat, block[:w_o])
    [proj, { per_head: per_head, concat: concat }]
  end

  # Mask scores[i, j] for j > query_offset + i.
  def apply_causal_mask!(scores, query_offset:)
    scores.each_with_index do |row, i|
      first_masked = query_offset + i + 1
      (first_masked...row.length).each { |j| row[j] = -1e30 }
    end
  end

  # FFN: relu(h · W_ff1) · W_ff2
  def feed_forward(h, block)
    pre    = Mat.matmul(h, block[:w_ff1])
    hidden = pre.map { |row| row.map { |v| v > 0 ? v : 0.0 } }
    out    = Mat.matmul(hidden, block[:w_ff2])
    [out, { pre: pre, hidden: hidden }]
  end

  # =====================================================================
  #  BACKWARD — uses the cached forward state to produce gradients.
  #
  #  Cross-entropy + softmax shortcut:
  #      dL/dlogits[i, c] = softmax(logits[i])[c] - 1[c == target_i]
  # =====================================================================

  def backward(token_ids)
    n_pred = token_ids.size - 1
    return zero_gradients if n_pred <= 0

    dlogits, total_loss = cross_entropy_grad(@cache[:logits], token_ids, n_pred)

    grad_lm_head = Mat.matmul(Mat.transpose(@cache[:x_final]), dlogits)
    dx_final     = Mat.matmul(dlogits, Mat.transpose(@lm_head))

    dx, grad_norm_final = rms_norm_backward(
      @cache[:x_block_out], @norm_final_gamma, @cache[:rms_final], dx_final
    )

    grad_blocks = Array.new(@n_layers)
    @blocks.each_with_index.to_a.reverse_each do |block, i|
      x_in = i.zero? ? @cache[:x_embed] : @cache[:blocks][i - 1][:x_out]
      dx, grad_blocks[i] = transformer_block_backward(dx, x_in, block, @cache[:blocks][i])
    end

    grad_token_embed, grad_pos_embed = embed_backward(token_ids, dx)

    {
      token_embed:      grad_token_embed,
      pos_embed:        grad_pos_embed,
      lm_head:          grad_lm_head,
      norm_final_gamma: grad_norm_final,
      blocks:           grad_blocks,
      loss:             total_loss / n_pred,
    }
  end

  def cross_entropy_grad(logits, token_ids, n_pred)
    dlogits    = Mat.zeros(logits.length, @vocab_size)
    total_loss = 0.0
    inv_n      = 1.0 / n_pred

    n_pred.times do |i|
      row    = logits[i]
      mx     = row.max
      exp    = row.map { |v| Math.exp(v - mx) }
      sum    = exp.sum
      target = token_ids[i + 1]

      total_loss += -Math.log([exp[target] / sum, 1e-12].max)
      exp.each_with_index { |e, c| dlogits[i][c] = (e / sum) * inv_n }
      dlogits[i][target] -= inv_n
    end

    [dlogits, total_loss]
  end

  # Backward through one block. Each helper returns (d_input, grads_for_its_params).
  def transformer_block_backward(dx_out, x_in, block, cache)
    # Residual on FFN sublayer: x_out = x_attn + ff_out → grad flows to both.
    d_h_norm2, ffn_grads = feed_forward_backward(dx_out, cache[:h_norm2], cache[:ff_cache], block)
    d_x_attn_via_norm, d_norm2_gamma = rms_norm_backward(
      cache[:x_attn], block[:norm2_gamma], cache[:rms2], d_h_norm2
    )
    d_x_attn = Mat.add(dx_out, d_x_attn_via_norm)

    # Residual on attention sublayer: x_attn = x_in + attn_proj.
    d_h_norm1, attn_grads = self_attention_backward(d_x_attn, cache[:h_norm1], cache[:attn_cache], block)
    d_x_in_via_norm, d_norm1_gamma = rms_norm_backward(
      x_in, block[:norm1_gamma], cache[:rms1], d_h_norm1
    )
    d_x_in = Mat.add(d_x_attn, d_x_in_via_norm)

    grads = ffn_grads.merge(attn_grads).merge(
      norm1_gamma: d_norm1_gamma, norm2_gamma: d_norm2_gamma
    )
    [d_x_in, grads]
  end

  def feed_forward_backward(d_ff_out, h, ff_cache, block)
    d_w_ff2  = Mat.matmul(Mat.transpose(ff_cache[:hidden]), d_ff_out)
    d_hidden = Mat.matmul(d_ff_out, Mat.transpose(block[:w_ff2]))

    # ReLU': pass gradient where pre-activation > 0, kill it elsewhere.
    d_pre = ff_cache[:pre].each_with_index.map do |row, i|
      row.each_with_index.map { |v, j| v > 0 ? d_hidden[i][j] : 0.0 }
    end

    d_w_ff1 = Mat.matmul(Mat.transpose(h), d_pre)
    d_h     = Mat.matmul(d_pre, Mat.transpose(block[:w_ff1]))

    [d_h, { w_ff1: d_w_ff1, w_ff2: d_w_ff2 }]
  end

  # Multi-head attention backward. Each head is independent until the final
  # output projection, so we loop over heads and sum the input-gradient
  # contributions back into d_h_in.
  def self_attention_backward(d_proj, h_in, attn_cache, block)
    d_w_o    = Mat.matmul(Mat.transpose(attn_cache[:concat]), d_proj)
    d_concat = Mat.matmul(d_proj, Mat.transpose(block[:w_o]))
    d_outs   = Mat.hsplit(d_concat, @n_heads)

    d_w_q_per_head = Array.new(@n_heads)
    d_w_k_per_head = Array.new(@n_heads)
    d_w_v_per_head = Array.new(@n_heads)
    d_h_in         = Mat.zeros(h_in.length, @d_model)
    inv_sqrt       = 1.0 / Math.sqrt(@d_head)

    @n_heads.times do |head_idx|
      head    = attn_cache[:per_head][head_idx]
      d_out_h = d_outs[head_idx]

      # out = attn · V
      d_attn = Mat.matmul(d_out_h, Mat.transpose(head[:v]))
      d_v    = Mat.matmul(Mat.transpose(head[:attn]), d_out_h)

      # Through softmax (masked entries had attn = 0 so contribute nothing).
      d_scores = softmax_rows_backward(head[:attn], d_attn)
      Mat.scale!(d_scores, inv_sqrt)

      # scores = Q · Kᵀ
      d_q = Mat.matmul(d_scores, head[:k])
      d_k = Mat.matmul(Mat.transpose(d_scores), head[:q])

      d_w_q_per_head[head_idx] = Mat.matmul(Mat.transpose(h_in), d_q)
      d_w_k_per_head[head_idx] = Mat.matmul(Mat.transpose(h_in), d_k)
      d_w_v_per_head[head_idx] = Mat.matmul(Mat.transpose(h_in), d_v)

      Mat.add!(d_h_in, Mat.matmul(d_q, Mat.transpose(block[:w_q][head_idx])))
      Mat.add!(d_h_in, Mat.matmul(d_k, Mat.transpose(block[:w_k][head_idx])))
      Mat.add!(d_h_in, Mat.matmul(d_v, Mat.transpose(block[:w_v][head_idx])))
    end

    [d_h_in, { w_q: d_w_q_per_head, w_k: d_w_k_per_head, w_v: d_w_v_per_head, w_o: d_w_o }]
  end

  # Row-wise softmax backward: d_scores[i,j] = attn[i,j] * (d_attn[i,j] - Σk attn[i,k]·d_attn[i,k])
  def softmax_rows_backward(softmax_out, d_softmax)
    softmax_out.each_with_index.map do |row, i|
      d_row = d_softmax[i]
      s     = row.zip(d_row).sum { |p, dp| p * dp }
      row.each_with_index.map { |p, j| p * (d_row[j] - s) }
    end
  end

  # RMSNorm backward.
  #   For y = gamma * x / r,  with r = sqrt(mean(x²) + eps):
  #     dL/dx_k    = (dy_k * gamma_k - x_k * coef) / r,
  #         coef = (Σ_j dy_j * gamma_j * x_j) / (d * r²)
  #     dL/dgamma_j (summed over rows) = Σ_rows dy_j * x_j / r
  def rms_norm_backward(x, gamma, rms, dy)
    d      = gamma.length
    dx     = Array.new(x.length) { Array.new(d, 0.0) }
    dgamma = Array.new(d, 0.0)

    x.each_with_index do |row, i|
      r     = rms[i]
      inner = 0.0
      d.times { |j| inner += dy[i][j] * gamma[j] * row[j] }
      coef  = inner / (d * r * r)

      d.times do |j|
        dx[i][j]   = (dy[i][j] * gamma[j] - row[j] * coef) / r
        dgamma[j] += dy[i][j] * row[j] / r
      end
    end

    [dx, dgamma]
  end

  # Embedding backward: each row of dx routes to its token's row in token_embed
  # and to position i's row in pos_embed. Repeated tokens accumulate.
  def embed_backward(token_ids, dx)
    grad_token = Mat.zeros(@vocab_size, @d_model)
    grad_pos   = Mat.zeros(@context_length, @d_model)

    token_ids.each_with_index do |tok, i|
      @d_model.times do |j|
        grad_token[tok][j] += dx[i][j]
        grad_pos[i][j]     += dx[i][j]
      end
    end

    [grad_token, grad_pos]
  end

  # =====================================================================
  #  GRADIENT BOOKKEEPING
  #
  #  All four operations (zero / accumulate / scale / apply) walk the same
  #  list of parameters. Define the walk once in two helpers; the operations
  #  become one-liners.
  # =====================================================================

  WEIGHT_KEYS = %i[w_o w_ff1 w_ff2].freeze
  HEAD_KEYS   = %i[w_q w_k w_v].freeze
  GAMMA_KEYS  = %i[norm1_gamma norm2_gamma].freeze

  # Every 2D parameter (or its gradient) in canonical order.
  def matrices_of(s)
    out = [s[:token_embed], s[:pos_embed], s[:lm_head]]
    s[:blocks].each do |b|
      HEAD_KEYS.each   { |k| b[k].each { |m| out << m } }
      WEIGHT_KEYS.each { |k| out << b[k] }
    end
    out
  end

  # Every 1D parameter (or its gradient) in canonical order.
  def vectors_of(s)
    out = [s[:norm_final_gamma]]
    s[:blocks].each { |b| GAMMA_KEYS.each { |k| out << b[k] } }
    out
  end

  def model_struct
    { token_embed: @token_embed, pos_embed: @pos_embed, lm_head: @lm_head,
      norm_final_gamma: @norm_final_gamma, blocks: @blocks }
  end

  def zero_gradients
    {
      token_embed:      Mat.zeros(@vocab_size, @d_model),
      pos_embed:        Mat.zeros(@context_length, @d_model),
      lm_head:          Mat.zeros(@d_model, @vocab_size),
      norm_final_gamma: Array.new(@d_model, 0.0),
      blocks: Array.new(@n_layers) {
        {
          norm1_gamma: Array.new(@d_model, 0.0),
          norm2_gamma: Array.new(@d_model, 0.0),
          w_q:   Array.new(@n_heads) { Mat.zeros(@d_model, @d_head) },
          w_k:   Array.new(@n_heads) { Mat.zeros(@d_model, @d_head) },
          w_v:   Array.new(@n_heads) { Mat.zeros(@d_model, @d_head) },
          w_o:   Mat.zeros(@d_model, @d_model),
          w_ff1: Mat.zeros(@d_model, @d_ff),
          w_ff2: Mat.zeros(@d_ff,    @d_model),
        }
      },
      loss: 0.0,
    }
  end

  def accumulate!(acc, grads)
    matrices_of(acc).zip(matrices_of(grads)) { |a, g| Mat.add!(a, g) }
    vectors_of(acc).zip(vectors_of(grads))   { |a, g| add_vec!(a, g) }
    acc[:loss] += grads[:loss]
  end

  def scale_gradients!(acc, s)
    matrices_of(acc).each { |m| Mat.scale!(m, s) }
    vectors_of(acc).each  { |v| scale_vec!(v, s) }
  end

  # Adam update for every parameter (matrix and vector alike).
  #
  #   m ← β1·m + (1−β1)·g          v ← β2·v + (1−β2)·g²
  #   m̂ = m / (1 − β1ᵗ)            v̂ = v / (1 − β2ᵗ)
  #   param -= lr · m̂ / (√v̂ + ε)
  def apply_gradients(grads, lr, beta1: 0.9, beta2: 0.999, eps: 1e-8)
    @adam_t += 1
    bc1 = 1.0 - beta1 ** @adam_t
    bc2 = 1.0 - beta2 ** @adam_t

    matrices_of(model_struct).zip(matrices_of(grads),
                                  matrices_of(@m_state),
                                  matrices_of(@v_state)) do |p, g, m, v|
      adam_step!(p, g, m, v, lr, beta1, beta2, eps, bc1, bc2)
    end
    vectors_of(model_struct).zip(vectors_of(grads),
                                 vectors_of(@m_state),
                                 vectors_of(@v_state)) do |p, g, m, v|
      adam_step_vec!(p, g, m, v, lr, beta1, beta2, eps, bc1, bc2)
    end
  end

  # =====================================================================
  #  TRAINING LOOP — the gradient accumulator is the whole point.
  #
  #     1. zero an accumulator (one slot per parameter)
  #     2. for each example: forward, backward, ADD grads into the accumulator
  #     3. divide by batch size  →  mean gradient
  #     4. apply once            →  one SGD step on the mean gradient
  # =====================================================================
  def train(sequences, epochs:, learning_rate:, batch_size: 32)
    puts "Training transformer LM"
    puts "  vocab=#{@vocab_size}  d_model=#{@d_model}  d_ff=#{@d_ff}  " \
         "n_heads=#{@n_heads}  n_layers=#{@n_layers}  context=#{@context_length}"
    puts "  examples=#{sequences.size}  epochs=#{epochs}  lr=#{learning_rate}  batch=#{batch_size}"
    started = Time.now

    epochs.times do |epoch|
      total_loss = 0.0
      n          = 0

      sequences.shuffle.each_slice(batch_size) do |batch|
        acc = zero_gradients
        batch.each do |seq|
          forward(seq)
          grads = backward(seq)
          accumulate!(acc, grads)
          total_loss += grads[:loss]
          n += 1
        end
        scale_gradients!(acc, 1.0 / batch.size)
        apply_gradients(acc, learning_rate)
      end

      puts "Epoch #{epoch + 1}/#{epochs}  mean_loss=#{(total_loss / [n, 1].max).round(4)}"
    end

    puts "Training completed in #{(Time.now - started).round(2)}s"
  end

  # =====================================================================
  #  GENERATION — autoregressive sampling, with KV cache.
  #
  #  Without a cache, each new token would re-encode the full context from
  #  scratch — O(n²) work per token in total. The cache keeps K and V from
  #  prior tokens so each new token only pays for itself.
  # =====================================================================
  def generate(prompt, max_tokens: 20, temperature: 1.0)
    tokens = text_to_token_ids(prompt)
    tokens = [0] if tokens.empty?

    cache  = empty_kv_cache
    logits = forward_with_cache(tokens, cache)
    out    = prompt.split

    max_tokens.times do
      next_id = sample_token(logits.last, temperature)
      break unless next_id
      out << @vocabulary[next_id]
      break if cache[:pos_offset] >= @context_length

      logits = forward_with_cache([next_id], cache)
    end

    out.join(" ")
  end

  def empty_kv_cache
    {
      pos_offset: 0,
      layers: Array.new(@n_layers) {
        { k: Array.new(@n_heads) { [] }, v: Array.new(@n_heads) { [] } }
      },
    }
  end

  # Run forward over `new_tokens` only, reusing K/V from `cache` for older
  # positions. Returns logits for the new tokens (length = new_tokens.size).
  def forward_with_cache(new_tokens, cache)
    start_pos = cache[:pos_offset]
    raise "context overflow" if start_pos + new_tokens.size > @context_length

    x = embed(new_tokens, start_pos: start_pos)

    @blocks.each_with_index do |block, layer_idx|
      layer_kv = cache[:layers][layer_idx]
      h, _     = rms_norm(x, block[:norm1_gamma])
      inv_sqrt = 1.0 / Math.sqrt(@d_head)

      head_outs = Array.new(@n_heads) do |head_idx|
        q = Mat.matmul(h, block[:w_q][head_idx])
        k = Mat.matmul(h, block[:w_k][head_idx])
        v = Mat.matmul(h, block[:w_v][head_idx])

        # Append new K/V rows to this layer/head's running cache.
        layer_kv[:k][head_idx].concat(k)
        layer_kv[:v][head_idx].concat(v)
        k_full = layer_kv[:k][head_idx]
        v_full = layer_kv[:v][head_idx]

        scores = Mat.matmul(q, Mat.transpose(k_full))
        Mat.scale!(scores, inv_sqrt)
        apply_causal_mask!(scores, query_offset: start_pos)

        attn = Mat.softmax_rows(scores)
        Mat.matmul(attn, v_full)
      end

      concat       = Mat.hstack(head_outs)
      x_after_attn = Mat.add(x, Mat.matmul(concat, block[:w_o]))

      h2, _   = rms_norm(x_after_attn, block[:norm2_gamma])
      pre     = Mat.matmul(h2, block[:w_ff1])
      hidden  = pre.map { |row| row.map { |v| v > 0 ? v : 0.0 } }
      ff_out  = Mat.matmul(hidden, block[:w_ff2])
      x       = Mat.add(x_after_attn, ff_out)
    end

    cache[:pos_offset] += new_tokens.size

    x_normed, _ = rms_norm(x, @norm_final_gamma)
    Mat.matmul(x_normed, @lm_head)
  end

  def sample_token(logits_row, temperature)
    return logits_row.each_with_index.max_by { |v, _| v }.last if temperature <= 0

    mx    = logits_row.max
    exp   = logits_row.map { |v| Math.exp((v - mx) / temperature) }
    sum   = exp.sum
    probs = exp.map { |e| e / sum }

    r   = rand
    cum = 0.0
    probs.each_with_index do |p, i|
      cum += p
      return i if r < cum
    end
    probs.length - 1
  end

  # =====================================================================
  #  Persistence (Spinel-friendly: plain text, no Marshal).
  #
  #  Format: line-based with tagged sections.
  #
  #    HEADER vocab_size d_model d_ff n_heads context_length n_layers
  #    VOCAB
  #    word_0
  #    word_1
  #    ...
  #    END_VOCAB
  #    M name rows cols
  #    v0 v1 v2 ...   (rows lines)
  #    V name length
  #    v0 v1 v2 ...   (one line)
  #    ...
  #    END
  # =====================================================================
  def save_to_file(filename)
    File.open(filename, "w") do |f|
      f.puts "HEADER #{@vocab_size} #{@d_model} #{@d_ff} #{@n_heads} #{@context_length} #{@n_layers}"
      f.puts "VOCAB"
      @vocabulary.each { |w| f.puts w }
      f.puts "END_VOCAB"

      named_matrices.each do |name, m|
        f.puts "M #{name} #{m.length} #{m[0].length}"
        m.each { |row| f.puts row.join(" ") }
      end
      named_vectors.each do |name, v|
        f.puts "V #{name} #{v.length}"
        f.puts v.join(" ")
      end
      f.puts "END"
    end
    puts "Network saved to #{filename}"
  end

  def self.load_from_file(filename)
    lines = File.readlines(filename, chomp: true)
    i     = 0

    header_parts                                          = lines[i].split
    raise "bad header" unless header_parts.first == "HEADER"
    vocab_size, d_model, d_ff, n_heads, context, n_layers = header_parts[1..6].map(&:to_i)
    i += 1

    raise "expected VOCAB" unless lines[i] == "VOCAB"
    i += 1
    vocabulary = []
    while lines[i] != "END_VOCAB"
      vocabulary << lines[i]
      i += 1
    end
    i += 1
    word_to_index = vocabulary.each_with_index.to_h

    nn = new(vocab_size: vocab_size, d_model: d_model, d_ff: d_ff, n_heads: n_heads,
            context_length: context, n_layers: n_layers,
            vocabulary: vocabulary, word_to_index: word_to_index)

    while lines[i] != "END"
      tag = lines[i].split
      case tag.first
      when "M"
        name, rows, cols = tag[1], tag[2].to_i, tag[3].to_i
        i += 1
        matrix = Array.new(rows) { |r| lines[i + r].split.map(&:to_f) }
        raise "matrix col mismatch" if matrix[0].length != cols
        i += rows
        nn.set_named_matrix(name, matrix)
      when "V"
        name, len = tag[1], tag[2].to_i
        i += 1
        vec = lines[i].split.map(&:to_f)
        raise "vec length mismatch (#{vec.size} != #{len})" unless vec.size == len
        i += 1
        nn.set_named_vector(name, vec)
      else
        raise "unknown tag #{tag.first}"
      end
    end

    puts "Network loaded from #{filename}"
    nn
  end

  # Lookup tables for save/load. Names follow the structure:
  #   token_embed, pos_embed, lm_head,
  #   block_<i>_w_q_<h>, block_<i>_w_k_<h>, block_<i>_w_v_<h>,
  #   block_<i>_w_o, block_<i>_w_ff1, block_<i>_w_ff2,
  #   norm_final_gamma, block_<i>_norm1_gamma, block_<i>_norm2_gamma
  def named_matrices
    pairs = [["token_embed", @token_embed], ["pos_embed", @pos_embed], ["lm_head", @lm_head]]
    @blocks.each_with_index do |b, i|
      @n_heads.times do |h|
        pairs << ["block_#{i}_w_q_#{h}", b[:w_q][h]]
        pairs << ["block_#{i}_w_k_#{h}", b[:w_k][h]]
        pairs << ["block_#{i}_w_v_#{h}", b[:w_v][h]]
      end
      pairs << ["block_#{i}_w_o",   b[:w_o]]
      pairs << ["block_#{i}_w_ff1", b[:w_ff1]]
      pairs << ["block_#{i}_w_ff2", b[:w_ff2]]
    end
    pairs
  end

  def named_vectors
    pairs = [["norm_final_gamma", @norm_final_gamma]]
    @blocks.each_with_index do |b, i|
      pairs << ["block_#{i}_norm1_gamma", b[:norm1_gamma]]
      pairs << ["block_#{i}_norm2_gamma", b[:norm2_gamma]]
    end
    pairs
  end

  def set_named_matrix(name, matrix)
    case name
    when "token_embed"      then @token_embed = matrix
    when "pos_embed"        then @pos_embed   = matrix
    when "lm_head"          then @lm_head     = matrix
    else
      m = name.match(/\Ablock_(\d+)_(w_o|w_ff1|w_ff2)\z/)
      if m
        @blocks[m[1].to_i][m[2].to_sym] = matrix
        return
      end
      m = name.match(/\Ablock_(\d+)_(w_q|w_k|w_v)_(\d+)\z/)
      raise "unknown matrix #{name}" unless m
      @blocks[m[1].to_i][m[2].to_sym][m[3].to_i] = matrix
    end
  end

  def set_named_vector(name, vec)
    if name == "norm_final_gamma"
      @norm_final_gamma = vec
      return
    end
    m = name.match(/\Ablock_(\d+)_(norm1_gamma|norm2_gamma)\z/)
    raise "unknown vector #{name}" unless m
    @blocks[m[1].to_i][m[2].to_sym] = vec
  end

  def model_size
    count = matrices_of(model_struct).sum { |m| m.length * m[0].length }
    count += vectors_of(model_struct).sum(&:length)
    {
      parameters: count,
      memory_kb:  (count * 4 / 1024.0).round(2),
      layers: { vocab: @vocab_size, d_model: @d_model, d_ff: @d_ff, n_heads: @n_heads,
                n_layers: @n_layers, context: @context_length },
    }
  end

  private

  def add_vec!(a, b);   a.length.times { |i| a[i] += b[i] }; a; end
  def scale_vec!(a, s); a.length.times { |i| a[i] *= s };    a; end

  def adam_step!(param, grad, m, v, lr, b1, b2, eps, bc1, bc2)
    rows = param.length
    cols = param[0].length
    rows.times do |i|
      pi, gi, mi, vi = param[i], grad[i], m[i], v[i]
      cols.times do |j|
        g = gi[j]
        mi[j] = b1 * mi[j] + (1 - b1) * g
        vi[j] = b2 * vi[j] + (1 - b2) * g * g
        pi[j] -= lr * (mi[j] / bc1) / (Math.sqrt(vi[j] / bc2) + eps)
      end
    end
  end

  def adam_step_vec!(param, grad, m, v, lr, b1, b2, eps, bc1, bc2)
    param.length.times do |i|
      g = grad[i]
      m[i] = b1 * m[i] + (1 - b1) * g
      v[i] = b2 * v[i] + (1 - b2) * g * g
      param[i] -= lr * (m[i] / bc1) / (Math.sqrt(v[i] / bc2) + eps)
    end
  end
end
